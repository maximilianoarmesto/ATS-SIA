# ─────────────────────────────────────────────────────────────────────────────
# ATS – SIA  |  Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your local environment:
#
#   cp .env.example .env
#
# The .env file is listed in .gitignore and must never be committed to source
# control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Database (Docker Compose) ────────────────────────────────────────────────
# These three variables are used by docker-compose.yml to configure the db
# service and to assemble DATABASE_URL for the app service automatically.
# Change them to match your desired credentials before running `docker compose up`.

POSTGRES_USER="ats_user"
POSTGRES_PASSWORD="ats_password"
POSTGRES_DB="ats_sia_db"

# Host port that the db service binds to on your machine (default: 5432).
# Change this if port 5432 is already in use.
POSTGRES_PORT=5432

# Host port that the app service binds to on your machine (default: 3000).
APP_PORT=3000


# ─── Database (Prisma / local development without Docker) ─────────────────────
# When running the application outside of Docker Compose (e.g. `npm run dev`
# against a local PostgreSQL instance), set DATABASE_URL directly.
#
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# When using Docker Compose, DATABASE_URL is assembled from the POSTGRES_*
# variables above and injected into the app container automatically — you do
# not need to set it here for the Compose workflow.
DATABASE_URL="postgresql://ats_user:ats_password@localhost:5432/ats_sia_db"


# ─── Seed ─────────────────────────────────────────────────────────────────────
# Controls whether the Docker container automatically seeds the database with
# sample data on startup (users, candidates, roles, applications).
# The seed script is fully idempotent — safe to run on already-seeded databases.
# Set to "false" in production environments where real data already exists.
SEED_DATABASE="true"


# ─── Application ─────────────────────────────────────────────────────────────
# Set to "development" locally. Next.js uses this to enable hot reload,
# detailed error overlays, and non-minified builds.
# Valid values: development | production | test
NODE_ENV="development"
