# ─────────────────────────────────────────────────────────────────────────────
# ATS – SIA  |  Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your local environment:
#
#   cp .env.example .env
#
# The .env file is listed in .gitignore and must never be committed to source
# control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local example (default PostgreSQL port 5432):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ats_sia_db"
#
# To create the database if it doesn't exist yet:
#   psql -U postgres -c "CREATE DATABASE ats_sia_db;"
DATABASE_URL="postgresql://username:password@localhost:5432/ats_sia_db"


# ─── Application ─────────────────────────────────────────────────────────────
# Set to "development" locally. Next.js uses this to enable hot reload,
# detailed error overlays, and non-minified builds.
# Valid values: development | production | test
NODE_ENV="development"
