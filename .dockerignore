# ─── Version control ─────────────────────────────────────────────────────────
.git
.gitignore

# ─── Node dependencies (re-installed inside the image) ───────────────────────
node_modules

# ─── Next.js build output (rebuilt inside the image) ─────────────────────────
.next

# ─── Local environment files (secrets must never be baked into the image) ────
.env
.env.*
!.env.example

# ─── Development / editor artefacts ──────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── TypeScript incremental build info ───────────────────────────────────────
*.tsbuildinfo

# ─── Test / coverage ─────────────────────────────────────────────────────────
coverage

# ─── Docker Compose init scripts (mounted as a volume, not baked into image) ─
docker
