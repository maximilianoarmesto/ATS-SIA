{
  "name": "ats-sia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test:accessibility": "npx tsx src/lib/accessibility/contrast.test.ts",
    "test:notes:validation": "npx tsx src/lib/validations/candidate-note.test.ts",
    "test:notes:collection-route": "npx tsx src/app/api/candidates/[id]/notes/route.test.ts",
    "test:notes:detail-route": "npx tsx \"src/app/api/candidates/[id]/notes/[noteId]/route.test.ts\"",
    "test:notes:component": "npx tsx src/components/candidate-notes.test.ts",
    "test:notes": "npm run test:notes:validation && npm run test:notes:collection-route && npm run test:notes:detail-route && npm run test:notes:component",
    "test:search": "npx tsx src/app/api/candidates/search/route.test.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:compile": "tsc --project tsconfig.seed.json",
    "db:seed:prod": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "5.7.1",
    "@types/node": "20.10.5",
    "@types/react": "18.2.45",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.4.16",
    "clsx": "2.0.0",
    "next": "14.0.4",
    "postcss": "8.4.32",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.3.6",
    "typescript": "5.3.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "6.15.0",
    "@typescript-eslint/parser": "6.15.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.0.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.0",
    "prettier": "3.1.1",
    "prettier-plugin-tailwindcss": "0.5.9",
    "prisma": "5.7.1",
    "tsx": "4.6.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
